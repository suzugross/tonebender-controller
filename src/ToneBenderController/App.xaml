<Application x:Class="ToneBenderController.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ToneBenderController.ViewModels"
             xmlns:views="clr-namespace:ToneBenderController.Views">

    <Application.Resources>

        <!-- ═══ ToneBender Color Palette ═══ -->

        <!-- Base -->
        <Color x:Key="ClrTextDark">#1E1E1E</Color>
        <Color x:Key="ClrTextGray">#787878</Color>
        <Color x:Key="ClrBorder">#C8C8C8</Color>
        <Color x:Key="ClrBanner">#000064</Color>
        <Color x:Key="ClrBannerText">#B4B4DC</Color>

        <!-- USB Creation (Green) -->
        <Color x:Key="ClrUsbBg">#E6F5ED</Color>
        <Color x:Key="ClrUsbAccent">#1E8C50</Color>
        <Color x:Key="ClrUsbBtn">#28A05A</Color>
        <Color x:Key="ClrUsbBtnHov">#3CB46E</Color>
        <Color x:Key="ClrUsbHeader">#146E3C</Color>

        <!-- WinPE Build (Blue — matches ToneBender Backup) -->
        <Color x:Key="ClrWinPeBg">#E6F0FF</Color>
        <Color x:Key="ClrWinPeAccent">#1E64C8</Color>
        <Color x:Key="ClrWinPeBtn">#2878DC</Color>
        <Color x:Key="ClrWinPeBtnHov">#3C8CF0</Color>
        <Color x:Key="ClrWinPeHeader">#144CA0</Color>

        <!-- ToneBender Config (Orange — matches ToneBender Restore) -->
        <Color x:Key="ClrConfigBg">#FFF0E1</Color>
        <Color x:Key="ClrConfigAccent">#DC781E</Color>
        <Color x:Key="ClrConfigBtn">#F08C28</Color>
        <Color x:Key="ClrConfigBtnHov">#FAA03C</Color>
        <Color x:Key="ClrConfigHeader">#B45A0A</Color>

        <!-- Image Prep (Purple) -->
        <Color x:Key="ClrImagePrepBg">#F0E6FF</Color>
        <Color x:Key="ClrImagePrepAccent">#6E32C8</Color>
        <Color x:Key="ClrImagePrepBtn">#7D46DC</Color>
        <Color x:Key="ClrImagePrepBtnHov">#9164F0</Color>
        <Color x:Key="ClrImagePrepHeader">#5A1EB4</Color>

        <!-- Execute -->
        <Color x:Key="ClrExecBtn">#64646E</Color>
        <Color x:Key="ClrExecBtnHov">#50505A</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="BrTextDark" Color="{StaticResource ClrTextDark}" />
        <SolidColorBrush x:Key="BrTextGray" Color="{StaticResource ClrTextGray}" />
        <SolidColorBrush x:Key="BrBorder" Color="{StaticResource ClrBorder}" />
        <SolidColorBrush x:Key="BrBanner" Color="{StaticResource ClrBanner}" />
        <SolidColorBrush x:Key="BrBannerText" Color="{StaticResource ClrBannerText}" />

        <SolidColorBrush x:Key="BrUsbBg" Color="{StaticResource ClrUsbBg}" />
        <SolidColorBrush x:Key="BrUsbAccent" Color="{StaticResource ClrUsbAccent}" />
        <SolidColorBrush x:Key="BrUsbBtn" Color="{StaticResource ClrUsbBtn}" />
        <SolidColorBrush x:Key="BrUsbHeader" Color="{StaticResource ClrUsbHeader}" />

        <SolidColorBrush x:Key="BrWinPeBg" Color="{StaticResource ClrWinPeBg}" />
        <SolidColorBrush x:Key="BrWinPeAccent" Color="{StaticResource ClrWinPeAccent}" />
        <SolidColorBrush x:Key="BrWinPeBtn" Color="{StaticResource ClrWinPeBtn}" />
        <SolidColorBrush x:Key="BrWinPeHeader" Color="{StaticResource ClrWinPeHeader}" />

        <SolidColorBrush x:Key="BrConfigBg" Color="{StaticResource ClrConfigBg}" />
        <SolidColorBrush x:Key="BrConfigAccent" Color="{StaticResource ClrConfigAccent}" />
        <SolidColorBrush x:Key="BrConfigBtn" Color="{StaticResource ClrConfigBtn}" />
        <SolidColorBrush x:Key="BrConfigHeader" Color="{StaticResource ClrConfigHeader}" />

        <SolidColorBrush x:Key="BrImagePrepBg" Color="{StaticResource ClrImagePrepBg}" />
        <SolidColorBrush x:Key="BrImagePrepAccent" Color="{StaticResource ClrImagePrepAccent}" />
        <SolidColorBrush x:Key="BrImagePrepBtn" Color="{StaticResource ClrImagePrepBtn}" />
        <SolidColorBrush x:Key="BrImagePrepHeader" Color="{StaticResource ClrImagePrepHeader}" />

        <SolidColorBrush x:Key="BrExecBtn" Color="{StaticResource ClrExecBtn}" />

        <!-- ═══ ViewModel → View DataTemplate ═══ -->
        <DataTemplate DataType="{x:Type vm:WinPeBuildViewModel}">
            <views:WinPeBuildView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ToneBenderConfigViewModel}">
            <views:ToneBenderConfigView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImagePrepViewModel}">
            <views:ImagePrepView />
        </DataTemplate>

        <!-- ═══ Tab button — 3D raised with accent bar (like ToneBender mode buttons) ═══ -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource BrTextDark}" />
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="outer" BorderThickness="1,1,1,0"
                                BorderBrush="{StaticResource BrBorder}">
                            <Border x:Name="inner"
                                    Background="{TemplateBinding Background}"
                                    Padding="16,6,16,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="inner" Property="Background" Value="#E8E8E8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Rounded action button (like ToneBender's Start Backup/Restore) ═══ -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Form label ═══ -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource BrTextDark}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ═══ Form TextBox ═══ -->
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource BrTextDark}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- ═══ Form ComboBox ═══ -->
        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource BrTextDark}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- ═══ Section header ═══ -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

    </Application.Resources>
</Application>
