<Window x:Class="ToneBenderController.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ToneBender Controller"
        Width="640" Height="520"
        MinWidth="640" MinHeight="520"
        Background="#F0F0F0"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <Binding Path="DataContext" RelativeSource="{RelativeSource Self}" />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!-- ═══ Banner (matches ToneBender dark navy banner) ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BrBanner}">
            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="ToneBender Controller"
                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="WinPE Builder &amp; USB Deploy Tool"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrBannerText}" />
            </StackPanel>
        </Border>

        <!-- ═══ Tab bar ═══ -->
        <Border Grid.Row="1" Background="#F0F0F0"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1"
                Padding="16,6,16,0">
            <DockPanel>
                <!-- Execute button (rightmost) -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding ExecuteCommand}"
                        Background="{StaticResource BrExecBtn}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Padding="20,5"
                        VerticalAlignment="Center"
                        Margin="12,0,0,6">
                    <TextBlock Text="{Binding ExecuteButtonText}" FontFamily="Segoe UI" FontSize="12"
                               FontWeight="Bold" Foreground="White" />
                </Button>

                <!-- Optional tabs (right-aligned, before Execute) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Bottom" Margin="0,0,8,0">
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="ToneBenderConfig"
                            Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="14" Fill="{StaticResource BrConfigAccent}"
                                       Margin="0,0,8,0" RadiusX="1" RadiusY="1" />
                            <TextBlock Text="ToneBender Config" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="ImagePrep"
                            Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="14" Fill="{StaticResource BrImagePrepAccent}"
                                       Margin="0,0,8,0" RadiusX="1" RadiusY="1" />
                            <TextBlock Text="Image Prep" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Main flow tabs (left-aligned) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="UsbCreation"
                            Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="14" Fill="{StaticResource BrUsbAccent}"
                                       Margin="0,0,8,0" RadiusX="1" RadiusY="1" />
                            <TextBlock Text="USB Creation" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="WinPeBuild"
                            Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="4" Height="14" Fill="{StaticResource BrWinPeAccent}"
                                       Margin="0,0,8,0" RadiusX="1" RadiusY="1" />
                            <TextBlock Text="WinPE Build" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Content area ═══ -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentPage}" />

        <!-- ═══ Status bar (matches ToneBender etched status bar) ═══ -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
            <Border Background="#F0F0F0" Padding="16,0">
                <TextBlock Text="{Binding StatusText}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrTextGray}"
                           VerticalAlignment="Center" />
            </Border>
        </Border>
    </Grid>
</Window>
