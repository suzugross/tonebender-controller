<UserControl x:Class="ToneBenderController.Views.UsbCreationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrUsbBg}">

    <StackPanel Margin="16">

        <!-- Header -->
        <TextBlock Text="USB Creation"
                   Style="{StaticResource SectionHeaderStyle}"
                   Foreground="{StaticResource BrUsbHeader}" />

        <!-- Drive Selection -->
        <TextBlock Text="Target Drive" Style="{StaticResource FormLabelStyle}"
                   FontWeight="Bold" Margin="0,0,0,6" />
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding UsbDrives}"
                      SelectedItem="{Binding SelectedDrive}"
                      Style="{StaticResource FormComboBoxStyle}" />
            <Button Grid.Column="1"
                    Command="{Binding RefreshDrivesCommand}"
                    Background="{StaticResource BrUsbBtn}"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="16,4" Margin="8,0,0,0">
                <TextBlock Text="Refresh" FontFamily="Segoe UI" FontSize="12"
                           Foreground="White" />
            </Button>
        </Grid>

        <!-- Partition Layout -->
        <TextBlock Text="Partition Layout" Style="{StaticResource FormLabelStyle}"
                   FontWeight="Bold" Margin="0,0,0,6" />
        <Border Background="White" BorderBrush="{StaticResource BrBorder}"
                BorderThickness="1" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="34" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="WINPE (FAT32)"
                           Style="{StaticResource FormLabelStyle}" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding WinPeSizeMB}"
                         Style="{StaticResource FormTextBoxStyle}" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="MB"
                           Style="{StaticResource FormLabelStyle}" Margin="6,0,0,0" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="DATA (NTFS)"
                           Style="{StaticResource FormLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="Remaining space"
                           Foreground="{StaticResource BrTextGray}"
                           FontFamily="Segoe UI" FontSize="13" FontStyle="Italic"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
