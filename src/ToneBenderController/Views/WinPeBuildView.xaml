<UserControl x:Class="ToneBenderController.Views.WinPeBuildView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ToneBenderController.Converters"
             Background="{StaticResource BrWinPeBg}">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />

        <!-- Visible when Mode = Full or PartitionOnly -->
        <Style x:Key="ShowOnFullOrPartition" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Mode}" Value="Full">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Mode}" Value="PartitionOnly">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Visible when Mode = Full or BuildOnly -->
        <Style x:Key="ShowOnFullOrBuild" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Mode}" Value="Full">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Mode}" Value="BuildOnly">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hidden only when Mode = PartitionOnly (drivers apply to Full/BuildOnly/DriverOnly) -->
        <Style x:Key="HideOnPartitionOnly" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Mode}" Value="PartitionOnly">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Visible only when Mode = BuildOnly -->
        <Style x:Key="ShowOnBuildOnly" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Mode}" Value="BuildOnly">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Visible only when Mode = DriverOnly -->
        <Style x:Key="ShowOnDriverOnly" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Mode}" Value="DriverOnly">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="WinPE USB Builder"
                   Style="{StaticResource SectionHeaderStyle}"
                   Foreground="{StaticResource BrWinPeHeader}" />

        <!-- Mode selector -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Mode" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <ComboBox ItemsSource="{Binding AvailableModes}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Mode"
                      SelectedValue="{Binding Mode}"
                      Style="{StaticResource FormComboBoxStyle}" />
        </StackPanel>

        <!-- Target Drive + Partition Layout (Full / PartitionOnly) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8"
                    Style="{StaticResource ShowOnFullOrPartition}">
            <TextBlock Text="Target Drive" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding UsbDrives}"
                          SelectedItem="{Binding SelectedDrive}"
                          Style="{StaticResource FormComboBoxStyle}" />
                <Button Grid.Column="1"
                        Command="{Binding RefreshDrivesCommand}"
                        Background="{StaticResource BrWinPeBtn}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Padding="16,4" Margin="8,0,0,0">
                    <TextBlock Text="Refresh" FontFamily="Segoe UI" FontSize="12"
                               Foreground="White" />
                </Button>
            </Grid>

            <Border Background="White" BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="1" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="WINPE (FAT32)"
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding WinPeSizeMB}"
                             Style="{StaticResource FormTextBoxStyle}" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="MB"
                               Style="{StaticResource FormLabelStyle}" Margin="6,0,0,0" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="DATA (NTFS)"
                               Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="Remaining space"
                               Foreground="{StaticResource BrTextGray}"
                               FontFamily="Segoe UI" FontSize="13" FontStyle="Italic"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Build Profile (Full / BuildOnly) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8"
                    Style="{StaticResource ShowOnFullOrBuild}">
            <TextBlock Text="Build Profile" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <ComboBox ItemsSource="{Binding AvailableProfiles}"
                      SelectedItem="{Binding SelectedProfile}"
                      Style="{StaticResource FormComboBoxStyle}" />
            <TextBlock Text="{Binding ProfileDetail}"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{StaticResource BrTextGray}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Build Output Directory (BuildOnly) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8"
                    Style="{StaticResource ShowOnBuildOnly}">
            <TextBlock Text="Output Directory (workspace)" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..."
                        Command="{Binding BrowseBuildOutputDirectoryCommand}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Background="{StaticResource BrWinPeBtn}"
                        Padding="10,4" Margin="4,0,0,0" />
                <TextBox Text="{Binding BuildOutputDirectory}"
                         Style="{StaticResource FormTextBoxStyle}"
                         IsReadOnly="True" />
            </DockPanel>
            <CheckBox IsChecked="{Binding BuildGenerateIso}"
                      FontFamily="Segoe UI" FontSize="12"
                      Margin="0,6,0,0">
                <TextBlock Text="Also generate ISO (next to workspace folder)"
                           FontFamily="Segoe UI" FontSize="12" />
            </CheckBox>
            <TextBlock Text="WARNING: existing contents of the output directory will be deleted."
                       FontFamily="Segoe UI" FontSize="11" FontStyle="Italic"
                       Foreground="{StaticResource BrTextGray}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Existing Workspace (DriverOnly) -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8"
                    Style="{StaticResource ShowOnDriverOnly}">
            <TextBlock Text="Existing PE Workspace" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..."
                        Command="{Binding BrowseWorkspacePathCommand}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Background="{StaticResource BrWinPeBtn}"
                        Padding="10,4" Margin="4,0,0,0" />
                <TextBox Text="{Binding WorkspacePath}"
                         Style="{StaticResource FormTextBoxStyle}"
                         IsReadOnly="True" />
            </DockPanel>
            <TextBlock Text="Must be a copype workspace containing media\sources\boot.wim."
                       FontFamily="Segoe UI" FontSize="11" FontStyle="Italic"
                       Foreground="{StaticResource BrTextGray}"
                       Margin="0,4,0,0" />
            <CheckBox IsChecked="{Binding DriverRegenerateIso}"
                      FontFamily="Segoe UI" FontSize="12"
                      Margin="0,6,0,0">
                <TextBlock Text="Regenerate ISO after driver injection"
                           FontFamily="Segoe UI" FontSize="12" />
            </CheckBox>
        </StackPanel>

        <!-- OEM Drivers (Full / BuildOnly / DriverOnly) -->
        <StackPanel Grid.Row="6" Margin="0,0,0,8"
                    Style="{StaticResource HideOnPartitionOnly}">
            <TextBlock Text="OEM Drivers" Style="{StaticResource FormLabelStyle}"
                       FontWeight="Bold" Margin="0,0,0,6" />
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Clear"
                        Command="{Binding ClearDriverDirectoryCommand}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Background="{StaticResource BrExecBtn}"
                        Padding="10,4" Margin="4,0,0,0" />
                <Button DockPanel.Dock="Right" Content="Browse..."
                        Command="{Binding BrowseDriverDirectoryCommand}"
                        Style="{StaticResource RoundedButtonStyle}"
                        Background="{StaticResource BrWinPeBtn}"
                        Padding="10,4" Margin="4,0,0,0" />
                <TextBox Text="{Binding DriverDirectory}"
                         Style="{StaticResource FormTextBoxStyle}"
                         IsReadOnly="True" />
            </DockPanel>
            <TextBlock FontFamily="Segoe UI" FontSize="11"
                       Foreground="{StaticResource BrTextGray}"
                       Margin="0,4,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Driver folder selected." />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DriverDirectory}" Value="">
                                <Setter Property="Text" Value="(none — driver injection will be skipped)" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Build Status (always visible) -->
        <TextBlock Grid.Row="7" Text="Status" Style="{StaticResource FormLabelStyle}"
                   FontWeight="Bold" Margin="0,0,0,6" />
        <Border Grid.Row="8" Background="White" BorderBrush="{StaticResource BrBorder}"
                BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
            <StackPanel>
                <ProgressBar Value="{Binding BuildProgress}"
                             Maximum="100" Height="18"
                             Foreground="{StaticResource BrWinPeAccent}"
                             Background="#E0E0E0"
                             BorderBrush="{StaticResource BrBorder}"
                             BorderThickness="1"
                             Margin="0,0,0,6" />
                <TextBlock Text="{Binding BuildStatus}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrTextGray}" />
            </StackPanel>
        </Border>

        <!-- Build Log -->
        <Border Grid.Row="9" Background="White"
                BorderBrush="{StaticResource BrBorder}"
                BorderThickness="1">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding BuildLog}"
                              Padding="8,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas" FontSize="11"
                                       Margin="0,1">
                                <Run Text="{Binding Time, Mode=OneTime}"
                                     Foreground="{StaticResource BrTextGray}" />
                                <Run Text=" " />
                                <Run Text="{Binding Message, Mode=OneTime}"
                                     Foreground="{Binding Status,
                                         Mode=OneTime,
                                         Converter={StaticResource StatusToColorConverter}}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
